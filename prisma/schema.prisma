generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Game {
  id        String   @id @default(cuid())
  code      String   @unique
  players   Player[]
  rounds    Round[]
  createdAt DateTime @default(now())
}

model Player {
  id     String @id @default(cuid())
  name   String
  order  Int
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Card {
  id         String     @id @default(cuid())
  slug       String     @unique
  text       String
  level      Int        @default(1)
  answer     String?
  answerNote String?
  categories Category[]
  rounds     Round[]
  createdAt  DateTime   @default(now())
}

model Round {
  id        String   @id @default(cuid())
  gameId    String
  cardId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  payload   Json
  createdAt DateTime @default(now())
}

model Category {
  id    String @id @default(cuid())
  key   String @unique
  name  String
  color String
  cards Card[]
}
